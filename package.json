{
  "name": "alea-deck",
  "version": "0.0.0-semantic-release",
  "description": "Uniform and weighted shuffling and sampling with Alea",
  "keywords": [
    "alea",
    "math",
    "random"
  ],
  "license": "MIT",
  "author": "Kenan Yildirim <kenan@kenany.me> (https://kenany.me/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kenany/alea-deck.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "types": "dist/index.d.cts",
  "main": "dist/index.cjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./*.mjs": {
      "default": "./dist/*.mjs"
    },
    "./*.cjs": {
      "default": "./dist/*.cjs"
    },
    "./*": {
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE.txt"
  ],
  "engines": {
    "node": "22 || 24 || >=26"
  },
  "scripts": {
    "build": "tsdown && tsc --noEmit",
    "lint": "biome check",
    "test": "vitest run",
    "prepare": "pnpm build"
  },
  "dependencies": {
    "@thi.ng/checks": "^3.10.1",
    "alea-random": "^6.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@containerbase/semantic-release-pnpm": "1.4.2",
    "@kenan/biome-config": "1.0.6",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "semantic-release": "25.0.5",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
